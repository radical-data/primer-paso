# Root workspace and runtime config
package.json
pnpm-workspace.yaml
biome.jsonc
mise.toml
netlify.toml
.github/workflows/ci.yml
.env.example
.env.test
scripts/**

# App/package manifests and build config
apps/*/package.json
apps/*/svelte.config.js
apps/*/vite.config.ts
apps/*/tsconfig.json
apps/*/app.d.ts
apps/*/src/app.d.ts
apps/*/src/app.html
apps/*/src/hooks.server.ts

# Public app: domain logic, server logic, routing logic, tests
apps/public/src/lib/analytics/**
apps/public/src/lib/i18n/**
apps/public/src/lib/journey/**
apps/public/src/lib/organisations/**
apps/public/src/lib/server/**
apps/public/src/lib/triage/**
