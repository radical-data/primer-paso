apps/public/src/lib/index.test.ts
apps/public/src/lib/utils.ts
apps/public/src/params/**
apps/public/src/routes/**/+page.server.ts
apps/public/src/routes/**/+server.ts
apps/public/src/routes/sitemap.xml/**
apps/public/static/**

# Keep route shell/load behaviour, but avoid Svelte surface copy and styling
apps/public/src/routes/**/+layout.server.ts

# Organisation portal: server/auth/review behaviour
apps/org-portal/src/lib/server/**
apps/org-portal/src/hooks.server.ts
apps/org-portal/src/routes/**/+page.server.ts
apps/org-portal/src/routes/**/+server.ts

# Shared packages
packages/**

# Architecture and operational docs
