# Public app analytics and handoff configuration.
PUBLIC_MATOMO_URL=https://matomo.example.com
PUBLIC_MATOMO_ENABLED=false
PUBLIC_MATOMO_DIMENSION_LOCALE=1
PUBLIC_MATOMO_DIMENSION_ENVIRONMENT=2
PUBLIC_MATOMO_DIMENSION_ROUTE_GROUP=3
PUBLIC_MATOMO_DIMENSION_STEP_SLUG=4
PUBLIC_MATOMO_DIMENSION_RESULT_STATE=5
PUBLIC_MATOMO_DIMENSION_RECOMMENDED_ROUTE=6
PUBLIC_MATOMO_SITE_ID_PRODUCTION=1
PUBLIC_MATOMO_SITE_ID_TEST=2
PUBLIC_MATOMO_LOCAL_ANALYTICS=off
PUBLIC_MATOMO_PRODUCTION_HOSTS=primerpaso.org,www.primerpaso.org

# Certificate handoff.
PUBLIC_CERTIFICATE_HANDOFF_ENABLED=false
PUBLIC_ORG_PORTAL_URL=https://org.primerpaso.org

# Shared persistence.
# Runtime Postgres URL used by the public app and organisation portal.
#
# For hosted Supabase on Netlify/serverless, use the Transaction pooler connection
# string from the Supabase dashboard, not a browser/public key.
#
# Example shape:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
#
# Keep this value private. Never expose it as PUBLIC_*.
PRIVATE_DATABASE_URL=
PRIVATE_DATABASE_PROVIDER=supabase

# Supabase Auth for the organisation portal.
# Configure these from the Supabase project settings.
# Use the project's publishable key, which starts with sb_publishable_.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase Auth email delivery is configured in the Supabase dashboard:
# Authentication -> Emails -> SMTP Settings.
# Production must use custom SMTP; do not rely on Supabase's default email service.
# Local development may use a hosted Supabase project while this is false.
PRIVATE_ORG_PORTAL_CUSTOM_SMTP_CONFIGURED=false

# Organisation portal.
# local | test | preview | production
PRIVATE_ORG_PORTAL_ENVIRONMENT=local

# Optional local seed defaults.
PRIVATE_ORG_PORTAL_DEV_LOGIN_ENABLED=false
PRIVATE_ORG_PORTAL_DEV_MEMBER_EMAIL=volunteer@example.invalid
