PUBLIC_MATOMO_URL=https://matomo.example.com/

# Turn tracking on or off globally.
PUBLIC_MATOMO_ENABLED=false

PUBLIC_MATOMO_DIMENSION_LOCALE=1
PUBLIC_MATOMO_DIMENSION_ENVIRONMENT=2
PUBLIC_MATOMO_DIMENSION_ROUTE_GROUP=3
PUBLIC_MATOMO_DIMENSION_STEP_SLUG=4
PUBLIC_MATOMO_DIMENSION_RESULT_STATE=5
PUBLIC_MATOMO_DIMENSION_RECOMMENDED_ROUTE=6

# Separate Matomo site IDs by destination.
PUBLIC_MATOMO_SITE_ID_PRODUCTION=1
PUBLIC_MATOMO_SITE_ID_TEST=2

# Local development analytics target: off or test.
PUBLIC_MATOMO_LOCAL_ANALYTICS=off

# Comma-separated production hostnames only.
PUBLIC_MATOMO_PRODUCTION_HOSTS=primerpaso.org,www.primerpaso.org

# Public certificate draft handoff is intentionally disabled until the
# database-backed token flow exists.
PUBLIC_CERTIFICATE_HANDOFF_ENABLED=false

# Public base URL for the organisation portal. QR codes and handoff links
# point here with an opaque token reference.
PUBLIC_ORG_PORTAL_URL=https://org.primerpaso.org

# Server-side database URL used by the public app handoff flow and the
# organisation portal. Keep real values out of git.
# PRIVATE_DATABASE_URL=postgres://primer_paso:primer_paso@localhost:5432/primer_paso

# Local-only organisation portal development login.
#
# This must never be enabled in production. It exists so local development can
# test organisation roles, handoff review, audit logging, and certificate
# preparation before real authentication is integrated.
PRIVATE_ORG_PORTAL_DEV_LOGIN_ENABLED=false
PRIVATE_ORG_PORTAL_ENVIRONMENT=development

# Optional default member email for the local dev login screen.
# Seeded local examples include admin@example.invalid, volunteer@example.invalid,
# signer@example.invalid, volunteer-signer@example.invalid.
PRIVATE_ORG_PORTAL_DEV_MEMBER_EMAIL=volunteer-signer@example.invalid
