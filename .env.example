# Local development defaults.
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_ORG_PORTAL_URL=http://localhost:5174
PUBLIC_CERTIFICATE_HANDOFF_ENABLED=true

# Shared persistence.
# Local Supabase Postgres:
PRIVATE_DATABASE_PROVIDER=supabase
PRIVATE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#
# Hosted Supabase / production should use the private Postgres connection URL,
# preferably the transaction pooler URL for serverless deploys.
# Never expose this value through a PUBLIC_* variable.

# Organisation portal.
# local | test | preview | production
PRIVATE_ORG_PORTAL_ENVIRONMENT=local

# Production must use configured SMTP in Supabase Auth.
# Local development uses Supabase Inbucket, so this stays false locally.
PRIVATE_ORG_PORTAL_CUSTOM_SMTP_CONFIGURED=false

PRIVATE_ORG_PORTAL_DEV_LOGIN_ENABLED=false
PRIVATE_ORG_PORTAL_DEV_MEMBER_EMAIL=volunteer@example.invalid

# Supabase Auth for the organisation portal.
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#
# Run `pnpm supabase:start`, then `supabase status`, and copy the local anon key.
PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-key-from-supabase-status

# Public app analytics configuration.
PUBLIC_MATOMO_URL=https://matomo.example.com
PUBLIC_MATOMO_ENABLED=false
PUBLIC_MATOMO_DIMENSION_LOCALE=1
PUBLIC_MATOMO_DIMENSION_ENVIRONMENT=2
PUBLIC_MATOMO_DIMENSION_ROUTE_GROUP=3
PUBLIC_MATOMO_DIMENSION_STEP_SLUG=4
PUBLIC_MATOMO_DIMENSION_RESULT_STATE=5
PUBLIC_MATOMO_DIMENSION_RECOMMENDED_ROUTE=6
PUBLIC_MATOMO_SITE_ID_PRODUCTION=1
PUBLIC_MATOMO_SITE_ID_TEST=2
PUBLIC_MATOMO_LOCAL_ANALYTICS=off
PUBLIC_MATOMO_PRODUCTION_HOSTS=primerpaso.org,www.primerpaso.org

# Python PDF signer.
# Local example:
# PRIVATE_PDF_SIGNER_URL=http://127.0.0.1:8080
#
# Production example:
# PRIVATE_PDF_SIGNER_URL=https://<your-pdf-signer-service>
PRIVATE_PDF_SIGNER_URL=
PRIVATE_PDF_SIGNER_TOKEN=

# Base64-encoded 32-byte key used to encrypt stored organisation signing
# certificates and passphrases. Generate with:
# openssl rand -base64 32
PRIVATE_SIGNING_CERT_ENCRYPTION_KEY=

# Only needed when running the Python service directly.
PDF_SIGNER_TOKEN=
PDF_SIGNER_HOST=0.0.0.0
PDF_SIGNER_PORT=8080