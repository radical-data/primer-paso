{
	"name": "@primer-paso/public",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:netlify": "pnpm -w run check:public-deploy-env && pnpm build && pnpm check:netlify-output",
		"check:netlify-output": "test -d build && test -f build/_headers && test -d .netlify/functions-internal && test -f .netlify/functions-internal/sveltekit-render.mjs && test -d .netlify/server",
		"check:analytics-env": "node ../../scripts/check-matomo-env.mjs",
		"check:analytics-env:strict": "node ../../scripts/check-matomo-env.mjs --strict",
		"generate:provinces": "node ../../scripts/generate-provinces.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"format": "biome format . --write",
		"lint": "biome lint .",
		"check": "biome check .",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "node --env-file=../../.env.test ./node_modules/vitest/vitest.mjs run",
		"test:watch": "node --env-file=../../.env.test ./node_modules/vitest/vitest.mjs",
		"capture:visuals": "tsx scripts/capture-visuals.ts"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.14.0",
		"@primer-paso/certificate": "workspace:*",
		"@primer-paso/db": "workspace:*",
		"@primer-paso/ui": "workspace:*",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"fuse.js": "^7.1.0",
		"i18n-iso-countries": "^7.14.0",
		"pdf-lib": "^1.17.1",
		"qrcode": "^1.5.4",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.56.0",
		"@biomejs/biome": "2.4.15",
		"@sveltejs/adapter-netlify": "latest",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25",
		"@types/qrcode": "^1.5.5",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.20.6",
		"typescript": "^6.0.3",
		"vite": "^8.0.12",
		"vitest": "^4.1.6"
	}
}
