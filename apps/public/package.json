{
	"name": "@primer-paso/public",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"check:analytics-env": "node ../../scripts/check-matomo-env.mjs",
		"check:analytics-env:strict": "node ../../scripts/check-matomo-env.mjs --strict",
		"generate:provinces": "node ../../scripts/generate-provinces.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"format": "biome format . --write",
		"lint": "biome lint .",
		"check": "biome check .",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "node --env-file=../../.env.test ./node_modules/vitest/vitest.mjs run",
		"test:watch": "node --env-file=../../.env.test ./node_modules/vitest/vitest.mjs"
	},
	"dependencies": {
		"@primer-paso/ui": "workspace:*",
		"@primer-paso/certificate": "workspace:*",
		"@primer-paso/db": "workspace:*",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.8.0",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"fuse.js": "^7.1.0",
		"pdf-lib": "^1.17.1",
		"qrcode": "^1.5.4",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@sveltejs/adapter-netlify": "latest",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"@types/qrcode": "^1.5.5",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^3.0.0"
	}
}
