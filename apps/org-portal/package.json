{
	"name": "@primer-paso/org-portal",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 5174",
		"build": "vite build",
		"build:netlify": "pnpm -w run check:org-deploy-env && pnpm build && pnpm check:netlify-output",
		"check:netlify-output": "test -d build && test -f build/_headers && test -d .netlify/functions-internal && test -f .netlify/functions-internal/sveltekit-render.mjs && test -d .netlify/server",
		"preview": "vite preview --port 4174",
		"prepare": "svelte-kit sync || echo ''",
		"format": "biome format . --write",
		"lint": "biome lint .",
		"check": "biome check .",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "node --env-file=../../.env.test ./node_modules/vitest/vitest.mjs run --passWithNoTests",
		"test:watch": "node --env-file=../../.env.test ./node_modules/vitest/vitest.mjs --passWithNoTests"
	},
	"dependencies": {
		"@primer-paso/ui": "workspace:*",
		"@primer-paso/auth": "workspace:*",
		"@primer-paso/certificate": "workspace:*",
		"@primer-paso/db": "workspace:*",
		"@primer-paso/signing-client": "workspace:*",
		"@lucide/svelte": "^1.8.0",
		"@supabase/ssr": "^0.7.0",
		"@supabase/supabase-js": "^2.87.0",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@sveltejs/adapter-netlify": "latest",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	}
}
