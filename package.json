{
	"name": "primer-paso",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"engines": {
		"node": ">=24 <25"
	},
	"scripts": {
		"dev": "pnpm --filter @primer-paso/public dev",
		"dev:public": "pnpm --filter @primer-paso/public dev",
		"dev:org": "pnpm --filter @primer-paso/org-portal dev",
		"build": "pnpm -r --if-present build",
		"build:public": "pnpm --filter @primer-paso/public build",
		"check:analytics-env": "node scripts/check-matomo-env.mjs",
		"check:analytics-env:strict": "node scripts/check-matomo-env.mjs --strict",
		"generate:provinces": "pnpm --filter @primer-paso/public generate:provinces",
		"preview": "pnpm --filter @primer-paso/public preview",
		"format": "biome format . --write",
		"lint": "biome lint .",
		"check": "biome check .",
		"typecheck": "pnpm -r --if-present typecheck",
		"test": "pnpm -r --if-present test",
		"test:watch": "pnpm --filter @primer-paso/public test:watch"
	},
	"pnpm": {
		"overrides": {
			"vite": "$vite"
		},
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@sveltejs/kit",
			"@tailwindcss/oxide",
			"esbuild",
			"netlify-cli",
			"sharp",
			"unix-dgram"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/node": "^24",
		"netlify-cli": "^25.0.1",
		"tsx": "^4.20.6",
		"vite": "^8.0.7"
	}
}
