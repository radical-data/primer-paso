		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^3.0.0"
	}
