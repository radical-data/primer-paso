{
	"name": "primer-paso",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"engines": {
		"node": ">=24 <25"
	},
	"scripts": {
		"dev": "pnpm --filter @primer-paso/public dev",
		"dev:public": "pnpm --filter @primer-paso/public dev",
		"dev:org": "pnpm --filter @primer-paso/org-portal dev",
		"build": "pnpm -r --if-present build",
		"build:public": "pnpm --filter @primer-paso/public build",
		"build:org": "pnpm --filter @primer-paso/org-portal build",
		"check:analytics-env": "node --env-file-if-exists=.env scripts/check-matomo-env.mjs",
		"check:analytics-env:strict": "node --env-file-if-exists=.env scripts/check-matomo-env.mjs --strict",
		"check:org-env": "node --env-file-if-exists=.env scripts/check-org-portal-env.mjs",
		"check:org-env:strict": "node --env-file-if-exists=.env scripts/check-org-portal-env.mjs --strict",
		"check:db-runtime": "node --env-file-if-exists=.env scripts/check-db-runtime.mjs --smoke",
		"check:db-runtime:strict": "node --env-file-if-exists=.env scripts/check-db-runtime.mjs --strict --smoke",
		"check:public-deploy-env": "node --env-file-if-exists=.env scripts/check-matomo-env.mjs --strict && node --env-file-if-exists=.env scripts/check-db-runtime.mjs --strict",
		"check:org-deploy-env": "node --env-file-if-exists=.env scripts/check-org-portal-env.mjs --strict && node --env-file-if-exists=.env scripts/check-db-runtime.mjs --strict",
		"netlify:build:public": "pnpm --filter @primer-paso/public build:netlify",
		"netlify:build:org": "pnpm --filter @primer-paso/org-portal build:netlify",
		"generate:provinces": "pnpm --filter @primer-paso/public generate:provinces",
		"smoke:certificate-pilot": "node scripts/smoke-certificate-pilot.mjs",
		"supabase:start": "supabase start",
		"supabase:start:minimal": "supabase start -x studio,realtime,storage-api,imgproxy,edge-runtime,logflare,vector",
		"db:reset": "supabase db reset",
		"db:types": "supabase gen types typescript --local > packages/db/src/database.types.ts",
		"preview": "pnpm --filter @primer-paso/public preview",
		"db:migrate": "pnpm --filter @primer-paso/db migrate",
		"db:seed:local-org-portal": "node --env-file=.env --import tsx packages/db/scripts/seed-local-org-portal.ts",
		"format": "biome format . --write",
		"lint": "biome lint .",
		"check": "biome check .",
		"typecheck": "pnpm -r --if-present typecheck",
		"test": "pnpm -r --if-present test",
		"test:watch": "pnpm --filter @primer-paso/public test:watch"
	},
	"pnpm": {
		"overrides": {
			"vite": "$vite"
		},
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@sveltejs/kit",
			"@tailwindcss/oxide",
			"esbuild",
			"netlify-cli",
			"sharp",
			"supabase",
			"unix-dgram"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/node": "^24",
		"netlify-cli": "^25.0.1",
		"postgres": "^3.4.9",
		"repomix": "^1.13.1",
		"supabase": "^2.78.1",
		"tsx": "^4.20.6",
		"vite": "^8.0.7"
	}
}
