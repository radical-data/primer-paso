{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"declaration": true,
		"skipLibCheck": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["svelte"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "svelte.config.js"]
}
